{
  "name": "@meerkat-events/react",
  "version": "0.1.0",
  "description": "React hooks for Meerkat Q&A — fetch questions and receive real-time updates via SSE",
  "license": "MIT",
  "author": "Florian Dreschner <code@dreschner.eu>",
  "homepage": "https://github.com/meerkat-events/meerkat/tree/master/packages/react",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/meerkat-events/meerkat.git",
    "directory": "packages/react"
  },
  "bugs": {
    "url": "https://github.com/meerkat-events/meerkat/issues"
  },
  "keywords": [
    "meerkat",
    "react",
    "hooks",
    "qna",
    "questions",
    "real-time",
    "sse"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "swr": "^2.4.1"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
